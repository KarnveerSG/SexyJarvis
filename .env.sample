# Copy to .env and fill in. Quill reads these automatically.

# Required: your Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# Cursor plan (recommended primary) — Cursor Dashboard → API Keys
# CURSOR_API_KEY=crsr_...

# Provider: auto (Cursor → Claude → local) | cursor | anthropic | local
# QUILL_PROVIDER=auto
# QUILL_CURSOR_MODEL=auto
# QUILL_FALLBACK_MODEL=claude-sonnet-4-20250514

# Local LLM fallback (LM Studio / Ollama)
# LM_STUDIO_URL=http://localhost:1234/v1
# LM_MODEL=your-model-name

# Optional overrides
# QUILL_MODEL=claude-sonnet-4-20250514
# QUILL_MAX_TOKENS=4096
# QUILL_MAX_RETRIES=5
# QUILL_RETRY_DELAY=1.5
# QUILL_BASH_TIMEOUT=120
# QUILL_MAX_ITERATIONS=60
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# QUILL_CAVEMAN=false
# QUILL_VERBOSE_TOOLS=true
# QUILL_TTS_STYLE=intimate
# QUILL_TTS_RATE=-20%
# QUILL_TTS_PITCH=-4Hz
# QUILL_TTS=true
# QUILL_STT=true
# QUILL_TTS_VOICE=en-GB-SoniaNeural
# OPENAI_API_KEY=sk-...
# QUILL_STT_ENGINE=cloud
