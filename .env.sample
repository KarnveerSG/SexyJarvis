# Copy to .env and fill in. SexyJarvis reads these automatically.

# Required: your Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# Cursor plan (recommended primary) — Cursor Dashboard → API Keys
# CURSOR_API_KEY=crsr_...

# Provider: auto (Cursor → Claude → local) | cursor | anthropic | local
# SEXYJARVIS_PROVIDER=auto
# SEXYJARVIS_CURSOR_MODEL=auto
# SEXYJARVIS_FALLBACK_MODEL=claude-sonnet-4-20250514

# Local LLM fallback (LM Studio / Ollama)
# LM_STUDIO_URL=http://localhost:1234/v1
# LM_MODEL=your-model-name

# Optional overrides
# SEXYJARVIS_MODEL=claude-sonnet-4-20250514
# SEXYJARVIS_MAX_TOKENS=4096
# SEXYJARVIS_MAX_RETRIES=5
# SEXYJARVIS_RETRY_DELAY=1.5
# SEXYJARVIS_BASH_TIMEOUT=120
# SEXYJARVIS_MAX_ITERATIONS=60
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# SEXYJARVIS_CAVEMAN=false          # off = normal prose (default: on)
# SEXYJARVIS_VERBOSE_TOOLS=true     # show full tool args/results (default: off)
# SEXYJARVIS_TTS_STYLE=intimate      # intimate | playful | bright
# SEXYJARVIS_TTS_RATE=-20%          # override preset rate
# SEXYJARVIS_TTS_PITCH=-4Hz         # override preset pitch
# SEXYJARVIS_TTS=true
# SEXYJARVIS_STT=true
# SEXYJARVIS_TTS_VOICE=en-GB-SoniaNeural
# OPENAI_API_KEY=sk-...          # Whisper STT (cloud mode)
# SEXYJARVIS_STT_ENGINE=cloud    # cloud | offline
