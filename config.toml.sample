# SexyJarvis config — copy to config.toml in workspace or ~/.sexyjarvis/config.toml

[sexyjarvis]
provider = "auto"
cursor_model = "auto"
fallback_model = "claude-sonnet-4-20250514"
rtk_enabled = true
codegraph_enabled = true
caveman_enabled = true
verbose_tools = false
thinking_budget = 2048

